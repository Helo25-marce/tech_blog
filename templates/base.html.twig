<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <style>
:root {
  --primary: #1a2744;
  --primary-light: #2d3f6b;
  --accent: #c9a84c;
  --accent-dark: #a0803a;
  --bg: #f5f2eb;
  --bg-card: #ffffff;
  --bg-header: #1a2744;
  --bg-footer: #0f1829;
  --text: #2c2416;
  --text-muted: #6b5f4e;
  --text-light: #f5f2eb;
  --border: #ddd5c4;
  --code-bg: #1e2d4a;
}

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,400&display=swap');

body {
  font-family: 'Source Serif 4', 'Times New Roman', Georgia, serif;
  background: var(--bg);
  color: var(--text);
  font-size: 18px;
  line-height: 1.85;
  margin: 0;
  padding: 0;
}

h1, h2, h3, h4 {
  font-family: 'Playfair Display', 'Times New Roman', Georgia, serif;
}

h1 {
  font-size: clamp(2rem, 5vw, 3.2rem);
  color: var(--primary);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

h2 {
  font-size: clamp(1.4rem, 3vw, 2rem);
  color: var(--primary);
  font-weight: 600;
  margin: 2.5rem 0 1rem;
  border-left: 4px solid var(--accent);
  padding-left: 16px;
}

h3 {
  font-size: 1.25rem;
  color: var(--primary-light);
  font-weight: 600;
  margin: 2rem 0 0.75rem;
}

a {
  color: var(--accent-dark);
  text-decoration: underline;
  text-decoration-color: transparent;
  transition: text-decoration-color 0.2s;
}

a:hover {
  text-decoration-color: var(--accent-dark);
}

code, pre {
  font-family: 'Courier New', Consolas, monospace;
  background: var(--code-bg);
  color: #98d4fa;
  padding: 1.25rem 1.5rem;
  border-radius: 6px;
  font-size: 14px;
  line-height: 1.6;
  overflow-x: auto;
  border-left: 4px solid var(--primary);
  display: block;
  margin: 1.5rem 0;
}

/* HEADER */
header {
  background: var(--bg-header);
  border-bottom: 3px solid var(--accent);
  padding: 0;
  box-shadow: 0 2px 20px rgba(0,0,0,0.3);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
}

.logo {
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
}

.logo img {
  height: 44px;
  width: auto;
}

.logo-text {
  color: #fff;
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.logo-text span {
  color: var(--accent);
}

nav a {
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  font-family: Arial, sans-serif;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 8px 16px;
  border-radius: 4px;
  transition: all 0.25s;
  position: relative;
}

nav a::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 16px;
  right: 16px;
  height: 2px;
  background: var(--accent);
  transform: scaleX(0);
  transition: transform 0.25s;
}

nav a:hover {
  color: var(--accent);
}

nav a:hover::after {
  transform: scaleX(1);
}

/* FOOTER */
footer {
  background: var(--bg-footer);
  border-top: 3px solid var(--accent);
  color: rgba(255,255,255,0.7);
  padding: 3rem 2rem 1.5rem;
  margin-top: 4rem;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
}

.footer-brand {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  color: var(--accent);
  margin-bottom: 0.5rem;
}

.footer-copy {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  margin-top: 2rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.1);
}

/* ARTICLES / CARDS */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 2rem;
  margin: 2.5rem 0;
}

.article-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.75rem;
  transition: transform 0.25s, box-shadow 0.25s;
  position: relative;
  overflow: hidden;
}

.article-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--accent), var(--accent-dark));
}

.article-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(26,39,68,0.12);
}

.article-card h2 {
  border: none;
  padding: 0;
  font-size: 1.35rem;
  margin-top: 0;
}

.article-meta {
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 0.75rem;
  font-family: Arial, sans-serif;
}

.read-more {
  display: inline-block;
  margin-top: 1rem;
  background: var(--primary);
  color: var(--accent);
  padding: 8px 20px;
  border-radius: 4px;
  text-decoration: none;
  font-family: Arial, sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  transition: background 0.2s, transform 0.15s;
}

.read-more:hover {
  background: var(--primary-light);
  transform: translateX(3px);
  text-decoration: none;
}

/* FORMULAIRE COMMENTAIRES */
.comment-form {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 2rem;
  margin: 2rem 0;
}

.form-group {
  margin-bottom: 1.25rem;
}

label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 6px;
  color: var(--text-muted);
  font-family: Arial, sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

input[type="text"], textarea {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-radius: 6px;
  font-family: inherit;
  font-size: 15px;
  background: var(--bg);
  color: var(--text);
  transition: border-color 0.2s, box-shadow 0.2s;
}

input:focus, textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.15);
}

button[type="submit"] {
  background: var(--accent);
  color: var(--text-light);
  padding: 10px 28px;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  font-family: Arial, sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  transition: all 0.2s;
}

button[type="submit"]:hover {
  filter: brightness(1.1);
  transform: translateY(-1px);
}

/* COMMENTAIRES EXISTANTS */
.comments-list {
  margin: 2rem 0;
}

.comment {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 4px solid var(--accent);
  border-radius: 0 8px 8px 0;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1rem;
  transition: border-left-color 0.2s;
}

.comment:hover {
  border-left-color: var(--primary);
}

.comment-author {
  font-size: 13px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4px;
}

.comment-date {
  font-size: 12px;
  color: var(--text-muted);
  font-style: italic;
}

/* LAYOUT GÉNÉRAL */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
}

main {
  min-height: calc(100vh - 200px);
  padding: 2.5rem 0;
}

.hero {
  padding: 3rem 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2.5rem;
}

.hero h1 {
  margin-bottom: 0.5rem;
}

.hero p {
  font-size: 1.1rem;
  color: var(--text-muted);
  max-width: 680px;
}

/* ANIMATIONS */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-20px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

main {
  animation: fadeInUp 0.5s ease both;
}

.article-card {
  animation: fadeInUp 0.5s ease both;
}

.article-card:nth-child(1) {
  animation-delay: 0.05s;
}

.article-card:nth-child(2) {
  animation-delay: 0.12s;
}

.article-card:nth-child(3) {
  animation-delay: 0.19s;
}

header {
  animation: slideInLeft 0.4s ease both;
}

/* RESPONSIF */
@media (max-width: 768px) {
  .header-inner {
    flex-direction: column;
    height: auto;
    padding: 1rem;
    gap: 0.75rem;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
  }
  .articles-grid {
    grid-template-columns: 1fr;
  }
  h1 {
    font-size: 1.8rem;
  }
}

/* CATÉGORIES */
.category-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  margin: 0 4px 4px 0;
  background: var(--primary);
  color: var(--text-light);
  font-family: Arial, sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
        </style>
{% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
<header>
    <div class="header-inner">
        <a href="{{ path('app_home') }}" class="logo">
            <img src="{{ asset('images/logo-tech-trendz.png') }}" alt="Tech Blog">
            <span class="logo-text">Tech <span>Blog</span></span>
        </a>
        <nav>
            <a href="{{ path('app_home') }}">Accueil</a>
            <a href="{{ path('app_about') }}">À propos</a>
        </nav>
    </div>
</header>
        {% block body %}{% endblock %}

    <footer>
        <div class="footer-inner">
            <div class="footer-brand">Tech Blog</div>
            <div class="footer-copy">&copy; 2025 Tech Blog</div>
        </div>
    </footer>
</body>
</html> 
  


