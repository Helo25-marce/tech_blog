{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - Tech Blog{% endblock %}

{% block body %}
<main>
<div class="container">
<div class="hero">
<h1>{{ post.title }}</h1>
<div>
{% for cat in post.categories %}
<span class="category-badge">{{ cat.name }}</span>
{% endfor %}
</div>
</div>

<div>{{ post.content|nl2br }}</div>

<h2>Commentaires ({{ post.comments|length }})</h2>

<div class="comments-list">
{% for comment in post.comments %}
<div class="comment">
<div class="comment-author">{{ comment.username }}</div>
<div class="comment-date">{{ comment.createdAt|date('d/m/Y H:i') }}</div>
<p>{{ comment.content|nl2br }}</p>
</div>
{% else %}
<p>Aucun commentaire pour le moment.</p>
{% endfor %}
</div>

<h2>Ajouter un commentaire</h2>

<div class="comment-form">
{{ form_start(comment_form) }}
{{ form_widget(comment_form) }}
<button type="submit">Ajouter le commentaire</button>
{{ form_end(comment_form) }}
</div>
</div>
</main>
{% endblock %}